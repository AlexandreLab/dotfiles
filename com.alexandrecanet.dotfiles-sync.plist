<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.alexandrecanet.dotfiles-sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/alexandrecanet/dotfiles/sync.sh</string>
    </array>

    <!-- Run once a day at 18:00 -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>18</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- Also run when the Mac wakes if the last scheduled run was missed -->
    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/alexandrecanet/dotfiles/.sync.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/alexandrecanet/dotfiles/.sync.log</string>
</dict>
</plist>
